docker {
    enabled = true
    // docker.runOptions = '-u $(id -u):$(id -g)' our docker is under restricted cgroups/WSL/institutional Linux setups and forcing the container user/group this way causes setgroups to fail, so remove this custom Docker user option.
    runOptions = "-v \$HOME:\$HOME "
}
singularity.enabled = false

params {
    outdir         = "${baseDir}/results"
    reads          = "data/*_{r1,R1,r2,R2}.fastq.gz"
    busco_lineage  = 'bacteria_odb10'
    min_contig_len = 500
    kraken_db      = null
    virulence_db   = null
    // Resource management defaults — override on the CLI with
    //   --global_cpus 8 --global_memory '32 GB'
    // or per-stage, e.g.:
    //   --cpus_spades 16 --mem_spades '64 GB'
    global_cpus    = 2
    global_memory  = '4 GB'
    cpus_spades    = null
    mem_spades     = null
    cpus_busco     = null
    mem_busco      = null
    cpus_kraken2   = null
    mem_kraken2    = null
    cpus_quast     = null
    mem_quast      = null
}

process {
    executor = 'local'
    // Fallback for stages that do NOT declare a dynamic cpus/memory directive.
    // Any process with `cpus { ... }` / `memory { ... }` overrides these.
    cpus = 2
    memory = '4 GB'

    withName: SANITY_CHECK {
        shell = ['/bin/bash', '-euo', 'pipefail']
    }
    withName: FASTQC_RAW {
        container = 'staphb/fastqc:0.12.1'
    }
    withName: FASTP {
        container = 'quay.io/biocontainers/fastp:0.23.4--h5f740d0_0'
    }
    withName: FASTQC_TRIMMED {
        container = 'staphb/fastqc:0.12.1'
    }
    withName: RETENTION_TRACK {
        container = 'ubuntu:22.04'
    }
    withName: SPADES {
        container = 'staphb/spades:3.15.5'
    }
    withName: FILTER_CONTIGS {
        container = 'ubuntu:22.04'
    }
    withName: QUAST {
        container = 'staphb/quast:5.2.0'
    }
    withName: BUSCO {
        container = 'quay.io/biocontainers/busco:5.4.3--pyhdfd78af_0'
    }
    withName: BUSCO_SUMMARY {
        container = 'ubuntu:22.04'
    }
    withName: KRAKEN2 {
        container = 'staphb/kraken2:2.1.3'
    }
    withName: TB_PROFILER {
        container = 'staphb/tb-profiler:4.4.2'
    }
    withName: SISTR2 {
        container = 'staphb/sistr_cmd:1.1.1'
    }
    withName: AMRFINDER {
        container = 'ncbi/amr:latest'
    }
    withName: MLST {
        container = 'staphb/mlst:2.23.0'
    }
    withName: VIRULENCEFINDER {
        container = 'quay.io/biocontainers/virulencefinder:2.0.4--py310hff52083_0'
    }
    withName: MULTIQC {
        container = 'quay.io/biocontainers/multiqc:1.21--pyhdfd78af_0'
    }
}

timeline {
    enabled = true
    file    = "${baseDir}/results/pipeline_timeline.html"
}
report {
    enabled = true
    file    = "${baseDir}/results/pipeline_report.html"
}
trace {
    enabled = true
    fields  = 'task_id,process,status,exit,hash,script'
    file    = "${baseDir}/results/pipeline_trace.txt"
}
